# Fase 2 — política e auditoria (opcional)
# Copie para .env ou exporte no ambiente / Hermes mcp_servers.env

# Apenas estas tools (se definido, ignora denylist para exposição)
# INTEGRATOR_TOOL_ALLOWLIST=search_gmail,get_gmail_message,get_calendars_info

# Bloqueia tools específicas
# INTEGRATOR_TOOL_DENYLIST=send_gmail_message,delete_calendar_event

# Sobrescreve tools que exigem confirm=true (padrão: send_gmail_message,delete_calendar_event)
# INTEGRATOR_CONFIRM_REQUIRED_TOOLS=send_gmail_message

# Auditoria JSONL (sem argumentos / PII)
INTEGRATOR_AUDIT_LOG_ENABLED=true
# INTEGRATOR_AUDIT_LOG_FILE=/abs/path/audit.jsonl

# Logging rotativo (padrão: data/logs/, 5 MB × 5 backups app/erros, 10 audit)
# INTEGRATOR_LOG_LEVEL=DEBUG
# INTEGRATOR_LOG_MAX_BYTES=5242880
# INTEGRATOR_LOG_BACKUP_COUNT=5
# INTEGRATOR_AUDIT_LOG_MAX_BYTES=5242880
# INTEGRATOR_AUDIT_LOG_BACKUP_COUNT=10

# Fase 2 — política e auditoria (opcional)
# Copie para .env ou exporte no ambiente / Hermes mcp_servers.env

# Apenas estas tools (se definido, ignora denylist para exposição)
# INTEGRATOR_TOOL_ALLOWLIST=search_gmail,get_gmail_message,get_calendars_info

# Bloqueia tools específicas
# INTEGRATOR_TOOL_DENYLIST=send_gmail_message,delete_calendar_event

# Sobrescreve tools que exigem confirm=true (padrão inclui send/delete WhatsApp)
# INTEGRATOR_WHATSAPP_MAX_CACHED_MESSAGES_PER_CHAT=5000
# INTEGRATOR_WHATSAPP_PERSIST_CACHE=true
# INTEGRATOR_CONFIRM_REQUIRED_TOOLS=send_gmail_message

# WhatsApp (neonize via subprocess bridge — ver docs/WHATSAPP.md)
# INTEGRATOR_WHATSAPP_ENABLED=false
# INTEGRATOR_WHATSAPP_SESSION_DIR=data/whatsapp
# INTEGRATOR_WHATSAPP_MAX_MESSAGE_CHARS=800

# WhatsApp — transcrição automática de áudios (Apple Silicon, mlx-whisper)
# Habilita auto-transcrição no integrator serve (worker MCP) E no watch daemon
# INTEGRATOR_WHATSAPP_AUTO_TRANSCRIBE=true
# Modelo mlx-whisper (recomendado para M3 Pro/Max):
# INTEGRATOR_WHATSAPP_TRANSCRIBE_MODEL=mlx-community/whisper-large-v3-turbo
# Mais leve (M3 base 8 GB):
# INTEGRATOR_WHATSAPP_TRANSCRIBE_MODEL=mlx-community/whisper-large-v3-turbo-q4
# Idioma (vazio = auto-detect PT/EN/etc):
# INTEGRATOR_WHATSAPP_TRANSCRIBE_LANGUAGE=pt
# Prefixo da resposta de transcrição:
# INTEGRATOR_WHATSAPP_TRANSCRIBE_PREFIX=🎙️ 
# false = transcreve áudios enviados e recebidos; true = só recebidos
# INTEGRATOR_WHATSAPP_TRANSCRIBE_ONLY_INCOMING=false
# true = só chats privados; ignora grupos (@g.us) na auto-transcrição e na tool MCP (padrão)
# INTEGRATOR_WHATSAPP_TRANSCRIBE_PRIVATE_ONLY=true

# Auditoria JSONL (sem argumentos / PII)
INTEGRATOR_AUDIT_LOG_ENABLED=true
# Só grava audit em falhas (recomendado — não impacta performance em sucesso)
INTEGRATOR_AUDIT_LOG_SUCCESS=false
# INTEGRATOR_AUDIT_LOG_FILE=/abs/path/audit.jsonl

# Logging rotativo (padrão: data/logs/, 5 MB × 5 backups app/erros, 10 audit)
# INTEGRATOR_LOG_LEVEL=DEBUG
# INTEGRATOR_LOG_MAX_BYTES=5242880
# INTEGRATOR_LOG_BACKUP_COUNT=5
# INTEGRATOR_AUDIT_LOG_MAX_BYTES=5242880
# INTEGRATOR_AUDIT_LOG_BACKUP_COUNT=10
# INTEGRATOR_LOG_CONSOLE_ENABLED=false
# INTEGRATOR_LOG_TOOL_SUCCESS=false

# Docker / VPS deployment environment template
# Copy to .env at the project root and fill in values before running docker compose.

# ── Admin console authentication ──────────────────────────────────────────────
# Required when the service is exposed on a public IP or via Coolify.
INTEGRATOR_ADMIN_USERNAME=admin
INTEGRATOR_ADMIN_PASSWORD=change-me-strong-password

# ── Allowed hosts for the reverse-proxy domain ────────────────────────────────
# Set to your Coolify / Nginx domain so the admin UI loads correctly.
# Separate multiple domains with commas.  Leave empty for localhost-only.
# Example: INTEGRATOR_ALLOWED_HOSTS=mcp.peralles.com
INTEGRATOR_ALLOWED_HOSTS=mcp.peralles.com

# Public URL for OAuth redirect (must match Google Cloud Web client)
INTEGRATOR_OAUTH_PUBLIC_BASE_URL=https://mcp.peralles.com

# Docker/Coolify: disable macOS LaunchAgent hints in admin
INTEGRATOR_SKIP_MACOS_SERVICE=1

# ── Service binding ───────────────────────────────────────────────────────────
INTEGRATOR_SERVICE_HOST=0.0.0.0
INTEGRATOR_SERVICE_PORT=17320

# Public-facing port (docker compose maps this to container port 17320)
INTEGRATOR_PORT=17320

# ── WhatsApp transcription (CPU via faster-whisper) ───────────────────────────
# Set to true to enable automatic audio transcription.
# On first enable the model (~1.5 GB) is downloaded from Hugging Face.
INTEGRATOR_WHATSAPP_AUTO_TRANSCRIBE=false

# Whisper model size: tiny | base | small | medium | large-v3 | large-v3-turbo
# Recommendation for CPU-only VPS:
#   small        — fast (~1 GB RAM), good for pt-BR
#   large-v3-turbo — best quality, slower (~3 GB RAM)
INTEGRATOR_WHATSAPP_TRANSCRIBE_MODEL=small

# Language hint speeds up transcription (leave empty for auto-detection)
INTEGRATOR_WHATSAPP_TRANSCRIBE_LANGUAGE=pt

# Transcribe only private chats (not groups)?
INTEGRATOR_WHATSAPP_TRANSCRIBE_PRIVATE_ONLY=true

# Transcribe only incoming messages?
INTEGRATOR_WHATSAPP_TRANSCRIBE_ONLY_INCOMING=false

# ── Logging ───────────────────────────────────────────────────────────────────
INTEGRATOR_LOG_LEVEL=INFO
